@page "{id:int}"
@model ged_fdl_razor.Pages.Commune.DossierModel
@{
    ViewData["Title"] = "Dossier de financement";
    Layout = "_PublicLayout";
}
@section Styles {
    <link rel="stylesheet" href="~/css/Dossier.css" asp-append-version="true" />
}

<div class="fdl-container">

    <h1 class="fdl-title">Dossier de financement de @(Model.Commune?.Nom ?? "Nom inconnu")</h1>

    <form method="post" asp-page-handler="Logout" class="text-end mb-3">
        <button type="submit" class="fdl-btn fdl-btn-danger">Se déconnecter</button>
    </form>

    <div class="fdl-info">
        <p><strong>Email :</strong> @(Model.Commune?.Email ?? "Non renseigné")</p>
        <p><strong>District :</strong> @(Model.Commune?.District ?? "Non renseigné")</p>
        <p><strong>Région :</strong> @(Model.Commune?.Region ?? "Non renseigné")</p>
        <p><strong>Date de création :</strong> @(Model.Commune?.DateCreation.ToString("dd/MM/yyyy") ?? "Non renseignée")</p>
    </div>

    <hr />

    <h2 class="fdl-subtitle">Dossiers soumis</h2>

    @if (Model.Commune?.Dossiers?.Any() == true)
    {
        <div class="fdl-accordion">
            @foreach (var dossier in Model.Commune.Dossiers)
            {
                <div class="fdl-card">
                    <div class="fdl-card-header" onclick="this.nextElementSibling.classList.toggle('open')">
                        @dossier.Titre (@dossier.DateSoumission?.ToString("dd/MM/yyyy"))
                    </div>
                    <div class="fdl-card-body">
                        <h4>Documents</h4>
                        @if (dossier.Documents?.Any() == true)
                        {
                            <div class="fdl-table-wrapper">
                                <table class="fdl-table">
                                    <thead>
                                        <tr>
                                            <th>Nom</th>
                                            <th>Type</th>
                                            <th>ContentType</th>
                                            <th>Taille</th>
                                            <th>Fichier</th>
                                            <th>Date Upload</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var doc in dossier.Documents)
                                        {
                                            <tr>
                                                <td>@doc.Nom</td>
                                                <td>@doc.Type</td>
                                                <td>@doc.ContentType</td>
                                                <td>@doc.Taille</td>
                                                <td>
                                                    <a asp-page-handler="Download" asp-route-id="@doc.DocumentID" class="fdl-btn fdl-btn-success">Télécharger</a>
                                                    <a asp-page-handler="Open" asp-route-id="@doc.DocumentID" class="fdl-btn fdl-btn-primary">Ouvrir</a>
                                                </td>
                                                <td>@doc.DateUpload.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td>
                                                    <a asp-page="/Commune/Dossiers/Documents/Replace" asp-route-documentId="@doc.DocumentID" class="fdl-btn fdl-btn-warning">Remplacer</a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <a class="fdl-btn fdl-btn-success mt-2" asp-page="/Commune/Dossiers/Documents/Create" asp-route-dossierId="@dossier.Id">+ Ajouter un document</a>
                        }
                        else
                        {
                            <p>Aucun document soumis pour ce dossier.</p>
                            <a class="fdl-btn fdl-btn-success" asp-page="/Commune/Dossiers/Documents/Create" asp-route-dossierId="@dossier.Id">Ajouter un nouveau document</a>
                        }

                        @if (dossier.Remarques?.Any() == true)
                        {
                            <h5>Remarques</h5>
                            <ul>
                                @foreach (var rem in dossier.Remarques)
                                {
                                    <li>@rem.Texte</li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p>Aucun dossier soumis pour cette commune.</p>
        <a class="fdl-btn fdl-btn-success" asp-page="/Commune/Dossiers/Create" asp-route-CommuneId="@(Model.Commune?.CommuneID ?? 0)">Créer un nouveau dossier</a>
    }
</div>

<script>
    // Petites animations accordion
    document.querySelectorAll('.fdl-card-header').forEach(header => {
        header.addEventListener('click', () => {
            const body = header.nextElementSibling;
            body.classList.toggle('open');
        });
    });
</script>
