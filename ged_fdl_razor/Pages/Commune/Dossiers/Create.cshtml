@page "{communeId:int}"
@model ged_fdl_razor.Pages.Commune.Dossiers.CreateModel
@{
    ViewData["Title"] = "Créer un dossier de financement";
}

    <link rel="stylesheet" href="~/css/CreateDossier.css" asp-append-version="true" />


<h1>Créer un dossier pour @Model.Commune.Nom</h1>

<form method="post">
    <div class="form-group">
        <label asp-for="Dossier.Titre"></label>
        <input asp-for="Dossier.Titre" class="form-control" />
        <span asp-validation-for="Dossier.Titre" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Dossier.DateSoumission">Date de soumission (optionnelle)</label>
        <input asp-for="Dossier.DateSoumission" type="date" class="form-control" />
        <span asp-validation-for="Dossier.DateSoumission" class="text-danger"></span>
    </div>

    <input type="hidden" asp-for="Dossier.CommuneId" />

    <button type="submit" class="btn btn-primary mt-2">Créer</button>
    <a asp-page="/Commune/Dossier" asp-route-id="@Model.Commune.CommuneID" class="btn btn-secondary mt-2">Annuler</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
