@page
@model ged_fdl_razor.Pages.ListeDocumentsRequisModel
@{
    ViewData["Title"] = "Documents requis";
    Layout = "_PublicLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/liste-documents-fdl.css" asp-append-version="true" />
}

<div class="fdl-container">

    <header class="fdl-header">
        <h2>Dossier de Demande de Financement</h2>
        <p>Fonds de Développement Local (FDL)</p>

        <a asp-page="/Commune/Login" class="fdl-login-btn">
            🔐 Se connecter pour voir votre dossier
        </a>
    </header>

    <section class="fdl-info">
        Après la communication effectuée par le FDL, la commune doit transmettre
        un dossier complet de demande de financement comprenant les documents suivants :
    </section>

    <section class="fdl-grid">

        <div class="fdl-card">
            <h4>Dossier Administratif</h4>
            <ul>
                <li>Compte administratif N-1 avec avis favorable</li>
                <li>Budget Primitif / Programme N avec délibération</li>
                <li>Arrêté de nomination du Trésorier Communal</li>
            </ul>
        </div>

        <div class="fdl-card">
            <h4>Dossier Technique</h4>
            <ul>
                <li>Fiche d’Identification du Projet (FIP)</li>
                <li>Croquis / Plan de l’infrastructure</li>
                <li>Devis quantitatif détaillé</li>
            </ul>
        </div>

        <div class="fdl-card">
            <h4>Dossier Complémentaire</h4>
            <ul>
                <li>Extrait PDL II</li>
                <li>Délibération du Conseil Communal</li>
                <li>Situation foncière</li>
                <li>Autorisation STD</li>
                <li>Rapport final projet antérieur</li>
            </ul>
        </div>

    </section>

</div>
