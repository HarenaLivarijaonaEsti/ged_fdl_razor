@* _Layout.cshtml *@
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ged_fdl_razor</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Dossier.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminGlobal.css" asp-append-version="true" />
</head>

<body>
    <main role="main" class="pb-3 fdl-container">

        @{
            // Récupère le chemin actuel
            var path = Context.Request.Path.ToString().TrimEnd('/').ToLowerInvariant();
        }

        @* Afficher le bouton seulement si l'utilisateur est admin et que ce n'est pas la page Nav *@
        @if (User.Identity?.IsAuthenticated == true &&
                User.HasClaim(System.Security.Claims.ClaimTypes.Role, "Admin") &&
                path != "/admin/nav" &&
                path != "/admin/nav/index")
        {
            <span>Connecté : @User.Identity.Name</span>
            <form method="post" asp-page="/Admin/Index" asp-page-handler="Logout" style="display:inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-logout">Se déconnecter</button>
            </form>
        }

        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
