@page
@model ged_fdl_razor.Pages.Admin.Dossiers.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">Créer un nouveau dossier</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.DossierFinancement[0].Titre)</th>
            <th>@Html.DisplayNameFor(model => model.DossierFinancement[0].DateCreation)</th>
            <th>@Html.DisplayNameFor(model => model.DossierFinancement[0].DateSoumission)</th>
            <th>@Html.DisplayNameFor(model => model.DossierFinancement[0].Statut)</th>
            <th>@Html.DisplayNameFor(model => model.DossierFinancement[0].Commune)</th>
            <th>@Html.DisplayNameFor(model => model.DossierFinancement[0].DateValidation)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.DossierFinancement)
        {
            <tr>
                <td>
                    <a asp-page="/Admin/Documents/Index" asp-route-dossierId="@item.Id">
                        @item.Titre
                    </a>
                </td>
                <td>@Html.DisplayFor(modelItem => item.DateCreation)</td>
                <td>@Html.DisplayFor(modelItem => item.DateSoumission)</td>
                <td>@Html.DisplayFor(modelItem => item.Statut)</td>
                <td>@Html.DisplayFor(modelItem => item.Commune.Nom)</td>
                <td>@Html.DisplayFor(modelItem => item.DateValidation)</td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a> |
                    <!-- 🔑 Ajout remarque redirige correctement vers Create avec communeId -->
                    <a asp-page="/Admin/Remarques/Create"
                       asp-route-communeId="@item.CommuneId"
                       class="btn btn-sm btn-success">
                        Ajouter remarque
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>