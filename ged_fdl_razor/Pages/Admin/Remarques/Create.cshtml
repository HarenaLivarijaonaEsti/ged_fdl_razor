@page
@model ged_fdl_razor.Pages.Admin.Remarques.CreateModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Remarque</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Texte -->
            <div class="form-group mb-3">
                <span class="text-danger">*</span>
                <label asp-for="Remarque.Texte" class="control-label"></label>
                <input asp-for="Remarque.Texte" class="form-control" aria-required="true" />
                <span asp-validation-for="Remarque.Texte" class="text-danger"></span>
            </div>

            <!-- Commune -->
            <div class="form-group mb-3">
                <label asp-for="Remarque.CommuneId" class="control-label"></label>
                <select id="communeSelect"
                        asp-for="Remarque.CommuneId"
                        class="form-control"
                        asp-items="ViewBag.CommuneId">
                    <option value="">-- Sélectionner une commune --</option>
                </select>
                <span asp-validation-for="Remarque.CommuneId" class="text-danger"></span>
            </div>

            <!-- Dossier (chargé dynamiquement) -->
            <div class="form-group mb-3">
                <label asp-for="Remarque.DossierFinancementId" class="control-label"></label>
                <select id="dossierSelect"
                        asp-for="Remarque.DossierFinancementId"
                        class="form-control">
                    <option value="">-- Sélectionner un dossier --</option>
                </select>
                <span asp-validation-for="Remarque.DossierFinancementId" class="text-danger"></span>
            </div>

            <!-- Date -->
            <div class="form-group mb-3">
                <label asp-for="Remarque.DateCreation" class="control-label"></label>
                <input asp-for="Remarque.DateCreation" class="form-control" type="date" />
                <span asp-validation-for="Remarque.DateCreation" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-page="Index" class="btn btn-secondary">Back to List</a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function chargerDossiers(communeId, selectedDossierId = null) {
            var dossierSelect = document.getElementById("dossierSelect");
            dossierSelect.innerHTML = '<option value="">Chargement...</option>';

            if (communeId) {
                fetch('?handler=DossiersByCommune&communeId=' + communeId)
                    .then(response => response.json())
                    .then(data => {
                        dossierSelect.innerHTML = '<option value="">-- Sélectionner un dossier --</option>';

                        data.forEach(function (item) {
                            var option = document.createElement("option");
                            option.value = item.id;
                            option.text = item.titre;

                            // Préselection du dossier si on a un selectedDossierId
                            if (selectedDossierId && selectedDossierId == item.id) {
                                option.selected = true;
                            }

                            dossierSelect.appendChild(option);
                        });
                    });
            } else {
                dossierSelect.innerHTML = '<option value="">-- Sélectionner un dossier --</option>';
            }
        }

        // Au changement de commune
        document.getElementById("communeSelect").addEventListener("change", function () {
            chargerDossiers(this.value);
        });

        // Précharger automatiquement si communeId est déjà défini
        var initialCommuneId = document.getElementById("communeSelect").value;
        var initialDossierId = "@Model.Remarque.DossierFinancementId"; // <-- valeur pré-sélectionnée du dossier

        if (initialCommuneId) {
            chargerDossiers(initialCommuneId, initialDossierId);
        }
    </script>
}